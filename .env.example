# App
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Database (Prisma/PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public&sslmode=require

# Vapi
NEXT_PUBLIC_VAPI_ASSISTANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_VAPI_API_KEY=public_key_xxxxxxxxxxxxxxxxxxxxx

# Emails (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Admin
ADMIN_EMAIL=admin@example.com
